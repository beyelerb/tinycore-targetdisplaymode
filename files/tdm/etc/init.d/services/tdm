#!/bin/sh

case "${1}" in
	start)
		# enforce minimum frequency and powersave mode for all CPU cores via sysfs
		for cpu in /sys/devices/system/cpu/cpu[0-9]*/cpufreq; do
			[ -d "$cpu" ] || continue
			min=$(cat "$cpu/cpuinfo_min_freq" 2>/dev/null) || continue
			echo powersave > "$cpu/scaling_governor" 2>/dev/null || true
			echo "$min"    > "$cpu/scaling_max_freq"  2>/dev/null || true
			echo "$min"    > "$cpu/scaling_min_freq"  2>/dev/null || true
		done

		# spin down the internal hard drive after boot settles (runs from RAM so it stays down)
		(sleep 30 && hdparm -Y /dev/sda 2>/dev/null) &

		/usr/bin/tdm_on
		;;

	stop)
		/usr/bin/tdm_off
		;;

	*)
		exit 1
		;;
esac
